  | "b'ekok"         { VERB_DIG }
  | "b'eklink"       { VERB_DIG }
  | "b'ekink"        { VERB_DIG }
  | "b'enik"         { VERB_TRAVEL }
  | "b'eenink"       { VERB_TRAVEL }
