(* ============================================================
   qeqchi.yalex — Especificación léxica del idioma Q'eqchi'

   Correcciones aplicadas:
   - Bug 1: "eb'" duplicado → se usa solo para PLURAL_MARK;
            PRON_3PL usa "eb' li" (sintagma), aquí se captura
            como PLURAL_MARK y el parser lo trata como pronombre.
   - Bug 2: {word}+ → {word}  (word ya es letter+, no necesita +)
   - Bug 3: mayúscula al inicio de oración → se añaden variantes
            Wan/Wank/Laa'in/Ink'a'/Maak'a'/Naab'al/Jun/Juneq
   - Orden: las keywords específicas van ANTES que {word} para
            que el DFA haga longest-match correcto.
============================================================ *)

{
  let letter = [a-zA-Z']
  let digit  = [0-9]
  let ws     = [' ' '\t' '\n' '\r']
  let word   = {letter}+
}

rule tokens =

  (* ── Espacios: se IGNORAN — no se pasan al parser ────────────
     En Q'eqchi' (y en cualquier gramática), el parser no debe
     recibir tokens de espacio. El lexer los consume y continúa
     sin emitir token. Si tu motor yalex requiere retornar algo,
     cambia esto a { WHITESPACE } y agrega whitespace_opt a todas
     las reglas del yapar — pero lo correcto es skipear aquí.  *)
  {ws}+       { SKIP }

  (* ── Partículas funcionales — minúscula y mayúscula ──────────
     IMPORTANTE: van antes de {word} para que el DFA
     aplique longest-match y reconozca keywords primero.     *)
  | "li"          { ART }
  | "Li"          { ART }

  (* eb' = PLURAL_MARK (y también PRON_3PL en contexto —
     el parser distingue por posición en la oración)         *)
  | "eb'"         { PLURAL_MARK }
  | "Eb'"         { PLURAL_MARK }

  | "sa'"         { LOC_IN }
  | "Sa'"         { LOC_IN }
  | "chi"         { LOC_WITH }
  | "Chi"         { LOC_WITH }
  | "re"          { PREP_FOR }
  | "Re"          { PREP_FOR }
  | "ut"          { CONJ_AND }
  | "Ut"          { CONJ_AND }
  | "naq"         { COMP_THAT }
  | "Naq"         { COMP_THAT }
  | "jo'"         { ADV_LIKE }
  | "Jo'"         { ADV_LIKE }
  | "rik'in"      { PREP_WITH_INST }
  | "Rik'in"      { PREP_WITH_INST }
  | "ruk'"        { PREP_WITH_INST }
  | "Ruk'"        { PREP_WITH_INST }
  | "chijunileb'" { ADV_EVERYONE }
  | "Chijunileb'" { ADV_EVERYONE }
  | "chijunilex"  { ADV_EVERYONE }
  | "Chijunilex"  { ADV_EVERYONE }
  | "junjunqeb"   { ADV_EACH }
  | "Junjunqeb"   { ADV_EACH }
  | "junelik"     { ADV_ALWAYS }
  | "Junelik"     { ADV_ALWAYS }
  | "mayer"       { ADV_BEFORE }
  | "Mayer"       { ADV_BEFORE }
  | "wulaj"       { ADV_TOMORROW }
  | "Wulaj"       { ADV_TOMORROW }
  | "xkaanb'al"   { NOUN_NOON }
  | "Xkaanb'al"   { NOUN_NOON }

  (* ── Existencial — variantes con/sin mayúscula ─────────────── *)
  | "wankat"      { VERB_EXIST }
  | "Wankat"      { VERB_EXIST }
  | "wank"        { VERB_EXIST }
  | "Wank"        { VERB_EXIST }
  | "wan"         { VERB_EXIST }
  | "Wan"         { VERB_EXIST }

  (* ── Existencial progresivo (yoo + sufijo de persona) ───────
     yoo = forma progresiva de wan; el sufijo indica persona.
     Se mapean al mismo token para reutilizar reglas del parser. *)
  | "yookin"      { VERB_EXIST }
  | "Yookin"      { VERB_EXIST }
  | "yookat"      { VERB_EXIST }
  | "Yookat"      { VERB_EXIST }
  | "yookeb"      { VERB_EXIST }
  | "Yookeb"      { VERB_EXIST }
  | "yookeb'"     { VERB_EXIST }
  | "yoo"         { VERB_EXIST }
  | "Yoo"         { VERB_EXIST }
  | "wankin"      { VERB_EXIST }
  | "Wankin"      { VERB_EXIST }

  (* ── Pronombres ─────────────────────────────────────────────── *)
  | "laa'in"      { PRON_1S }
  | "Laa'in"      { PRON_1S }
  | "laa'at"      { PRON_2S }
  | "Laa'at"      { PRON_2S }
  | "laa'e"       { PRON_3S }
  | "Laa'e"       { PRON_3S }
  | "laa'o"       { PRON_1PL }
  | "Laa'o"       { PRON_1PL }
  | "laa'ex"      { PRON_2PL }
  | "Laa'ex"      { PRON_2PL }

  (* ── Aspecto verbal ─────────────────────────────────────────── *)
  | "x"           { COMP_ASPECT }

  (* ── Negación ─────────────────────────────────────────────── *)
  | "ink'a'"      { NEG }
  | "Ink'a'"      { NEG }
  | "maak'a'"     { NEG }
  | "Maak'a'"     { NEG }
  | "mak'a"       { NEG }
  | "Mak'a"       { NEG }
  | "ninko"       { NEG }
  | "Ninko"       { NEG }

  (* ── Interrogativos ─────────────────────────────────────────── *)
  | "K'a'ru"      { INTERROG_WHAT }
  | "k'a'ru"      { INTERROG_WHAT }
  | "K'aru"       { INTERROG_WHAT }
  | "k'aru"       { INTERROG_WHAT }
  | "Chanru"      { INTERROG_HOW }
  | "chanru"      { INTERROG_HOW }
  | "K'a'ut"      { INTERROG_WHY }
  | "k'a'ut"      { INTERROG_WHY }
  | "K'aut"       { INTERROG_WHY }
  | "Aniat"       { INTERROG_WHO }
  | "aniat"       { INTERROG_WHO }
  | "Ma"          { INTERROG_PART }
  | "ma"          { INTERROG_PART }

  (* ── Marcador de género ─────────────────────────────────────── *)
  | "aj"          { MASC_MARK }
  | "Aj"          { MASC_MARK }

  (* ── Verbos ─────────────────────────────────────────────────── *)
  | "k'anjelak"   { VERB_WORK }
  | "k'anjel"     { VERB_WORK }
  | "b'anow"      { VERB_DO }
  | "b'ank"       { VERB_DO }
  | "xike"        { VERB_GO }
  | "xik"         { VERB_GO }
  | "k'ulak"      { VERB_ARRIVE }
  | "k'ul"        { VERB_ARRIVE }
  | "k'ira"       { VERB_CURE }
  | "iloq"        { VERB_SEE }
  | "il"          { VERB_SEE }
  | "yejak"       { VERB_TEACH }
  | "tawb'"       { VERB_FIND }
  | "taw"         { VERB_FIND }
  | "loq'"        { VERB_BUY }
  | "k'ay"        { VERB_SELL }
  | "k'e"         { VERB_GIVE }
  | "ab'i"           { VERB_HEAR }
  | "ab'ink"         { VERB_HEAR }
  | "tz'iib'"        { VERB_WRITE }
  | "naw"            { VERB_KNOW }
  | "aatinank"       { VERB_SPEAK }
  | "aatinak"        { VERB_SPEAK }
  | "aatink"         { VERB_SPEAK }
  | "ajok"           { VERB_WANT }
  | "awk"            { VERB_PLANT }
  | "awok"           { VERB_PLANT }
  | "awink"          { VERB_PLANT }
  | "atisink"        { VERB_BATHE }
  | "atisiik"        { VERB_BATHE }
  | "b'atok"         { VERB_WRAP }
  | "b'atz'unk"      { VERB_PLAY }
  | "b'olotzib'k"    { VERB_PLAY }
