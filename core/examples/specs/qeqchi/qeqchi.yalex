  | "b'ichank"       { VERB_SING }
  | "b'ichaak"       { VERB_SING }
  | "b'ichlenk"      { VERB_SING }
  | "b'onok"         { VERB_PAINT }
  | "b'onolenk"      { VERB_PAINT }
  | "b'ojok"         { VERB_SEW }
  | "b'oje'k"        { VERB_SEW }
  | "b'oqok"         { VERB_INVITE }
  | "b'oqlenk"       { VERB_INVITE }
  | "b'isok"         { VERB_MEASURE }
  | "b'isonk"        { VERB_MEASURE }
  | "b'itonk"        { VERB_CARRY }
  | "b'itok"         { VERB_CARRY }
  | "b'eek"          { VERB_WALK }
  | "b'eejesink"     { VERB_WALK }
  | "b'eeresink"     { VERB_GUIDE }
  | "b'eeresinb'il"  { VERB_GUIDE }
  | "ajlank"         { VERB_COUNT }
  | "ajlaak"         { VERB_COUNT }
  | "b'ak'ok"        { VERB_TIE }
  | "b'ak'b'ak'ink"  { VERB_TIE }
  | "b'aqirk"        { VERB_SLIM }
  | "b'aqob'resink"  { VERB_SLIM }
  | "b'orok"         { VERB_UNDO }
  | "b'ornank"       { VERB_UNDO }
  | "b'alaq'ik"      { VERB_DECEIVE }
